# Datasets directory: ignore subfolders (large data, caches) but keep top-level
# files like DATASET.md tracked. The named entries below cover symlinks --
# git tracks a symlink as a small "file" whose content is the target path, so
# `datasets/*/` (which only matches directories) does not cover them.
datasets/*/
datasets/beat_english_v2.0.0
datasets/embody_3d_aiagent
datasets/data_cache
datasets/data_cache_backup

scripts/trainers/dataloaders/seamlessinteraction/
scripts/trainers/dataloaders/beatx/depreceated*
scripts/trainers/dataloaders/embody3d_dyadic/depreceated*

scripts/sanity_check_unified_dataset.py

# Maintainer-only release tooling (HF upload script, scratch tools, etc.).
# Public users do not need any of this — the user-facing download path is
# `miburi-download-checkpoints` (see miburi/download_checkpoints.py).
scripts/release/
scripts/slurm/

assets_dep/*/

configs/gtdm3_audiotext_ufl_25_embody3dbeatx_allspk.yaml